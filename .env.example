# --- Database (Postgres) ---
#
# DATABASE_URL is the POOLED connection used by the app at runtime.
# DIRECT_URL is the DIRECT (non-pooled) connection used only for migrations.
#
# Neon (production): copy both strings from the Neon dashboard.
#   - DATABASE_URL must use the "-pooler" host and append "&pgbouncer=true".
#   - DIRECT_URL uses the non-pooler host.
#   Both end with "?sslmode=require" (DATABASE_URL adds "&pgbouncer=true").
#
# Local: point both at your local Postgres database (no pooling needed locally).

DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"
